--- a/midp/build/javacall_psp/psp_mips.gmk
+++ b/midp/build/javacall_psp/psp_mips.gmk
@@ -48,7 +48,11 @@ TARGET_VM		= cldc_vm
 # Platform-specific compiler flags
 EXTRA_CPPFLAGS += -G0 -DPSP -fno-strict-aliasing
 EXTRA_CFLAGS += -G0 -DPSP -fno-strict-aliasing
-PATHSEP = \;
+# Classpath separator: the original Cygwin build used ';' (Windows), but on the
+# Linux host build javac/jar/preverify expect ':'. A ';'-joined classpath is
+# seen as one bogus path, which broke MIDP preverify (couldn't resolve
+# java.lang.Object for the JSR-172 java.rmi classes).
+PATHSEP = :
 
