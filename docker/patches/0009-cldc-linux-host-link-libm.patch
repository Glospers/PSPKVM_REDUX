diff --git a/cldc/build/share/jvm.make b/cldc/build/share/jvm.make
index 13045064..a7ced216 100644
--- a/cldc/build/share/jvm.make
+++ b/cldc/build/share/jvm.make
@@ -1629,10 +1629,19 @@ ifeq ("$(ENABLE_STATIC_LINK)-$(IsTarget)", "true-true")
 LINK_FLAGS             += -static
 endif
 
-# statically link romgen, so that it can be used on another Linux distribution
-# that may have an incompatible libc.so
+# NOTE: upstream statically linked romgen for cross-distro portability, but the
+# 32-bit static glibc on a modern host cannot resolve fmod/fmodf (FloatSupport_c)
+# even with libm forced. The generator runs in-place in the build container, so
+# a dynamic link is fine — leave romgen dynamic.
 ifeq ($(host_os)-$(IsRomGen), linux-true)
-LINK_FLAGS             += -static
+# LINK_FLAGS           += -static
+endif
+
+# FloatSupport_c (fmod/fmodf) is linked into the host generators even when the
+# C interpreter isn't enabled, so libm must be linked explicitly (modern glibc
+# no longer folds these into libc).
+ifeq ($(host_os), linux)
+LINK_FLAGS             += -lm
 endif
 
 ifeq ($(PROFILING), true)
